{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "statelint-ui",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "-e",
        "import('./src/serve.js').catch(() => import('./src/serve.ts')).then(m => m.startConsole(['src'], 4477)).then(({url}) => console.log('listening', url))"
      ],
      "port": 4477
    },
    {
      "name": "statelint-ui-vue",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "-e",
        "import('./src/serve.ts').then(m => m.startConsole(['examples/vue-app'], 4478)).then(({url}) => console.log('listening', url))"
      ],
      "port": 4478
    },
    {
      "name": "statelint-ui-react",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "-e",
        "import('./src/serve.ts').then(m => m.startConsole(['examples/react-app'], 4479)).then(({url}) => console.log('listening', url))"
      ],
      "port": 4479
    }
  ]
}
