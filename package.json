{
  "name": "statelint",
  "version": "0.0.0",
  "description": "An architecture linter for React state — across every state tool, on every PR.",
  "type": "module",
  "bin": {
    "statelint": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}
